{
  "name": "project-translator-workspace",
  "private": true,
  "version": "0.20.0",
  "description": "Project Translator monorepo workspace",
  "repository": {
    "type": "git",
    "url": "https://github.com/Project-Translation/project_translator"
  },
  "workspaces": [
    "packages/core",
    "packages/vscode-extension",
    "packages/cli"
  ],
  "scripts": {
    "changelog": "node scripts/generate-changelog.mjs",
    "build": "npm run build -w packages/core && npm run build -w packages/vscode-extension && npm run build -w packages/cli",
    "compile": "npm run compile -w packages/core && npm run compile -w packages/vscode-extension && npm run compile -w packages/cli",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "lint": "npm run lint -w packages/core && npm run lint -w packages/vscode-extension && npm run lint -w packages/cli",
    "test": "npm run test -w packages/core && npm run test -w packages/cli",
    "package:extension": "npm run build -w packages/core && npm run package -w packages/vscode-extension",
    "publish:vscode": "npm run build -w packages/core && npm run publish:vscode -w packages/vscode-extension",
    "publish:ovsx": "npm run package:extension && npm run publish:ovsx -w packages/vscode-extension",
    "publish:npm": "npm run build -w packages/core && npm run publish:npm -w packages/cli",
    "pack:cli": "npm pack -w packages/cli",
    "watch:extension": "npm run watch -w packages/vscode-extension",
    "watch:cli": "npm run watch -w packages/cli",
    "deps:install": "npm install --no-fund",
    "update": "npm update --no-fund"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bindings": "^1.5.0",
    "commander": "^14.0.1",
    "diff": "^5.2.2",
    "diff-match-patch": "^1.0.5",
    "glob": "^11.0.1",
    "isbinaryfile": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.3",
    "openai": "^4.85.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^14.18.63",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/vsce": "^3.6.0",
    "chai": "^5.2.0",
    "esbuild": "^0.25.1",
    "eslint": "^9.23.0",
    "mocha": "^11.5.0",
    "ovsx": "^0.10.6",
    "sinon": "^20.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^4.0.0"
  },
  "overrides": {
    "undici": "7.24.4",
    "qs": "6.14.2",
    "serialize-javascript": "7.0.5",
    "brace-expansion": "5.0.5",
    "lodash": "4.18.1",
    "@eslint/config-array": {
      "minimatch": "3.1.4"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.4"
    },
    "eslint": {
      "minimatch": "3.1.4"
    },
    "@vscode/vsce": {
      "minimatch": "3.1.4"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    },
    "mocha": {
      "minimatch": "9.0.7"
    },
    "glob": {
      "minimatch": "10.2.3"
    }
  }
}
